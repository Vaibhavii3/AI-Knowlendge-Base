{
  "info": {
    "name": "AI Knowledge Base API",
    "_postman_id": "c3fef2cf-2e10-4bcf-a0b0-0e11cf7c8c38",
    "description": "Postman collection for the AI Knowledge Base (RAG) API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "q", "value": "example" },
    { "key": "query", "value": "example" },
    { "key": "question", "value": "What is this document about?" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/", "host": [ "{{baseUrl}}" ], "path": [ "" ] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Passw0rd!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "auth", "register" ]
            }
          }
        },
        {
          "name": "POST /api/auth/login (sets token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Passw0rd!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "auth", "login" ]
            }
          }
        },
        {
          "name": "GET /api/auth/me",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "auth", "me" ]
            }
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "GET /api/documents/demo-pdf (download demo PDF)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/documents/demo-pdf",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "documents", "demo-pdf" ]
            }
          }
        },
        {
          "name": "POST /api/documents/demo-ingest (create demo chunks)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/documents/demo-ingest",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "documents", "demo-ingest" ]
            }
          }
        },
        {
          "name": "GET /api/documents/chunks?limit=10 (debug)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/documents/chunks?limit=10",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "documents", "chunks" ],
              "query": [ { "key": "limit", "value": "10" } ]
            }
          }
        },
        {
          "name": "POST /api/documents/upload (multipart: file)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/documents/upload",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "documents", "upload" ]
            }
          }
        },
        {
          "name": "GET /api/documents/search?q={{q}}",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/api/documents/search?q={{q}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "documents", "search" ],
              "query": [ { "key": "q", "value": "{{q}}" } ]
            }
          }
        },
        {
          "name": "POST /api/documents/ask",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"question\": \"{{question}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/documents/ask",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "documents", "ask" ]
            }
          }
        }
      ]
    },
    {
      "name": "Search + AI",
      "item": [
        {
          "name": "POST /api/search/search (hybrid)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"{{query}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/search/search",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "search", "search" ]
            }
          }
        },
        {
          "name": "POST /api/ai/ask (RAG)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"question\": \"{{question}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/ai/ask",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "ai", "ask" ]
            }
          }
        },
        {
          "name": "POST /api/documents/search-chunks (vector)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"{{query}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/documents/search-chunks",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "documents", "search-chunks" ]
            }
          }
        },
        {
          "name": "POST /api/documents/vector-search (documents vector)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"query\": \"{{query}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/documents/vector-search",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "documents", "vector-search" ]
            }
          }
        }
      ]
    }
  ]
}

